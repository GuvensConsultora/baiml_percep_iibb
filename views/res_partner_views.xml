<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_res_partner_form_iibb" model="ir.ui.view">
        <field name="name">res.partner.form.baiml.iibb</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account.view_partner_property_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']" position="after">
                <page string="Percepciones IIBB" name="baiml_percep">
                    <group>
                        <field name="property_account_position_id" readonly="1"/>
                        <button name="baiml_sync_percep_desde_padron"
                                type="object"
                                string="Sincronizar desde padrón"
                                class="oe_highlight"/>
                    </group>
                    <p class="text-muted">
                        La posición fiscal se asigna automáticamente por el cron
                        nocturno o al importar un padrón. Las FPs generadas por
                        este módulo llevan el prefijo <b>BAIML Percep</b>. Si el
                        partner tiene una FP manual distinta, no se sobreescribe.
                    </p>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
