<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_res_partner_form_iibb" model="ir.ui.view">
        <field name="name">res.partner.form.baiml.iibb</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="account.view_partner_property_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']" position="after">
                <page string="Percepciones IIBB" name="baiml_percep">
                    <group>
                        <button name="baiml_sync_percep_desde_padron"
                                type="object"
                                string="Sincronizar desde padrón"
                                class="oe_highlight"/>
                    </group>
                    <field name="baiml_percep_ids">
                        <list editable="bottom">
                            <field name="jurisdiccion"/>
                            <field name="tax_id"/>
                            <field name="alicuota"/>
                            <field name="vigencia_desde"/>
                            <field name="vigencia_hasta"/>
                            <field name="origen"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
